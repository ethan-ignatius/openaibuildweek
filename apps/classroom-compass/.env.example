# Deterministic and credential-free by default.
CLASSROOM_COMPASS_REASONING_PROVIDER=fixture

# Headless runtime. All control endpoints bind to loopback only.
CC_CONTROL_PORT=4317
CC_DATA_DIR=.classroom-compass
CC_LESSON_TITLE=Comparing Decimals

# Optional local camera and microphone processes. Values are JSON arrays, never
# shell strings. Each process writes one event JSON object per stdout line.
# CC_CAMERA_COMMAND_JSON=["/opt/classroom-compass/bin/local-hand-raise-adapter","--device","0"]
# CC_MICROPHONE_COMMAND_JSON=["/opt/classroom-compass/bin/local-transcriber","--device","default"]

# Use the operating system speaker (`say` on macOS, `espeak` elsewhere).
# Otherwise tutor output is written to stdout for supervised integration.
CC_AUDIO_OUTPUT=console

# Optional institution-approved structured reasoning endpoint.
# The endpoint must return { "proposal": <InterpretationProposal> }.
# CLASSROOM_COMPASS_REASONING_PROVIDER=llm
# CLASSROOM_COMPASS_LLM_ENDPOINT=https://approved-provider.example/v1/classroom-proposal
# CLASSROOM_COMPASS_LLM_TOKEN=set-locally-never-commit
