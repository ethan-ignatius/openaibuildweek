{
  "name": "classroom-compass",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "tsx headless/cli.ts run",
    "build": "tsc --noEmit",
    "start": "tsx headless/cli.ts run",
    "tutor": "tsx headless/cli.ts",
    "tutor:demo": "tsx headless/cli.ts demo --fast",
    "teacher:demo": "tsx headless/cli.ts teacher-demo",
    "board:dev": "next dev -H 127.0.0.1 -p 3000",
    "board:build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "board:start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "voice:setup": "sh scripts/setup-local-whisper.sh",
    "voice:run": "CC_MICROPHONE_COMMAND_JSON='[\"node_modules/.bin/tsx\",\"headless/adapters/whisper-stream-adapter.ts\"]' tsx headless/cli.ts run",
    "voice:run:apple": "CC_MICROPHONE_COMMAND_JSON='[\".classroom-compass/bin/cc-macos-speech\",\"en-US\"]' tsx headless/cli.ts run",
    "voice:build:apple": "sh scripts/build-macos-speech-adapter.sh",
    "voice:build": "npm run voice:build:apple",
    "voice:meter:build": "sh scripts/build-sdl-microphone-meter.sh",
    "voice:meter": "npm run voice:meter:build && .classroom-compass/bin/cc-audio-meter \"${CC_WHISPER_CAPTURE_NAME:-Logitech Webcam C925e|Audio Streaming|MacBook Air Microphone|Microsoft Teams Audio}\" 10",
    "camera:build": "sh scripts/build-macos-hand-raise-adapter.sh",
    "camera:test": "CC_CAMERA_COMMAND_JSON='[\".classroom-compass/bin/cc-macos-hand-raise\",\"IC840 1080P HD\"]' CC_AUDIO_OUTPUT=system CC_TUTOR_PROVIDER=none tsx headless/cli.ts run",
    "room:run": "sh scripts/run-teacher-room.sh",
    "vision:setup": "sh scripts/setup-rtmpose-vision.sh",
    "vision:self-test": ".classroom-compass/vision-venv/bin/python headless/adapters/rtmpose-camera-adapter.py --self-test",
    "camera:preview": "CC_CAMERA_COMMAND_JSON='[\".classroom-compass/vision-venv/bin/python\",\"headless/adapters/rtmpose-camera-adapter.py\",\"--camera\",\"1\",\"--preview\"]' CC_AUDIO_OUTPUT=system CC_TUTOR_PROVIDER=none CC_STOP_WHEN_SENSORS_COMPLETE=1 tsx headless/cli.ts run",
    "room:preview": "CC_CAMERA_PREVIEW=1 sh scripts/run-teacher-room.sh",
    "ui:dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "ui:build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "ui:start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/unit tests/component tests/headless",
    "test:headless": "vitest run tests/headless",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "axe-core": "^4.12.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "^4.1.10",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
