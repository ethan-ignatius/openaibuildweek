{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://teacher-brain.local/schemas/journal-event.schema.json",
  "title": "Journal event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "session_id", "timestamp", "event_type", "payload", "sequence"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "timestamp": { "type": "string", "format": "date-time" },
    "event_type": {
      "type": "string",
      "enum": [
        "model.request",
        "model.response",
        "tool.call",
        "tool.result",
        "plan.revision",
        "perception.event",
        "voice.transcript",
        "eval.observation",
        "eval.prediction",
        "eval.metric",
        "session.started",
        "session.resumed",
        "session.interrupted",
        "session.ended"
      ]
    },
    "payload": { "type": "object" },
    "latency_ms": { "type": "number", "minimum": 0 },
    "sequence": { "type": "integer", "minimum": 0 },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "output", "total"],
      "properties": {
        "input": { "type": "integer", "minimum": 0 },
        "output": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
