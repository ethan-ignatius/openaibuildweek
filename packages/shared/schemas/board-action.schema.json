{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://teacher-brain.local/schemas/board-action.schema.json",
  "title": "Board action",
  "$defs": {
    "region": {
      "type": "string",
      "enum": ["top", "left", "center", "right", "bottom", "scratch"]
    },
    "elementId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "region", "text", "element_id"],
      "properties": {
        "type": { "const": "board.write_text" },
        "region": { "$ref": "#/$defs/region" },
        "text": { "type": "string", "minLength": 1, "maxLength": 10000 },
        "element_id": { "$ref": "#/$defs/elementId" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "region", "latex", "element_id"],
      "properties": {
        "type": { "const": "board.write_math" },
        "region": { "$ref": "#/$defs/region" },
        "latex": { "type": "string", "minLength": 1, "maxLength": 10000 },
        "element_id": { "$ref": "#/$defs/elementId" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "expr", "domain", "element_id"],
      "properties": {
        "type": { "const": "board.plot_function" },
        "expr": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "domain": {
          "type": "array",
          "prefixItems": [{ "type": "number" }, { "type": "number" }],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "element_id": { "$ref": "#/$defs/elementId" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "min", "max", "marks", "element_id"],
      "properties": {
        "type": { "const": "board.draw_number_line" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "marks": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value"],
            "properties": {
              "value": { "type": "number" },
              "label": { "type": "string", "maxLength": 100 }
            }
          }
        },
        "element_id": { "$ref": "#/$defs/elementId" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "fractions", "element_id"],
      "properties": {
        "type": { "const": "board.draw_fraction_bars" },
        "fractions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "type": "string", "pattern": "^[0-9]+/[1-9][0-9]*$" }
        },
        "element_id": { "$ref": "#/$defs/elementId" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "svg", "element_id"],
      "properties": {
        "type": { "const": "board.render_custom" },
        "svg": { "type": "string", "minLength": 1, "maxLength": 100000 },
        "element_id": { "$ref": "#/$defs/elementId" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "element_id", "style"],
      "properties": {
        "type": { "const": "board.highlight" },
        "element_id": { "$ref": "#/$defs/elementId" },
        "style": { "type": "string", "enum": ["pulse", "outline", "fill"] }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "element_id"],
      "properties": {
        "type": { "const": "board.unhighlight" },
        "element_id": { "$ref": "#/$defs/elementId" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "region"],
      "properties": {
        "type": { "const": "board.clear" },
        "region": {
          "type": "string",
          "enum": ["top", "left", "center", "right", "bottom", "scratch", "all"]
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "slide_ref"],
      "properties": {
        "type": { "const": "board.show_slide" },
        "slide_ref": { "type": "string", "minLength": 1, "maxLength": 2048 }
      }
    }
  ]
}
