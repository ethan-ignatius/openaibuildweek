# OpenAI credentials are read at runtime and are never written to journals.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_ATTEMPTS=3

# Server-side classroom speech. Never expose this key to browser code.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_TIMEOUT_MS=45000

# Harness ablation switches
TEACHER_BRAIN_TOOL_SURFACE=true
TEACHER_BRAIN_MEMORY_MODE=notes
TEACHER_BRAIN_PEDAGOGY_CONTEXT=on
TEACHER_BRAIN_ORCHESTRATION=true
TEACHER_BRAIN_JOURNALING=true

# Local server and board app
TEACHER_BRAIN_HOST=127.0.0.1
TEACHER_BRAIN_PORT=8000
VITE_API_URL=http://127.0.0.1:8000
VITE_BOARD_WS_URL=ws://127.0.0.1:8000/ws/board

# Classroom Compass sensor/audio runtime and Visual Stage projector. Use a
# teacher-authored seat/pseudonym map; camera code never identifies faces.
CC_TUTOR_PROVIDER=teacher-brain
CC_TEACHER_BRAIN_API_URL=http://127.0.0.1:8000
CC_TEACHER_BRAIN_TIMEOUT_MS=180000
CC_TEACHER_BRAIN_OBJECTIVE="Answer student questions accurately, check understanding, and reconnect to the lesson."
CC_TEACHER_BRAIN_ROSTER_JSON=[{"studentRef":"seat:camera-right","name":"Emanuel","language":"Spanish"},{"studentRef":"seat:camera-left","name":"Ethan","language":"English"}]
CC_TEACHER_BRAIN_OPENING_INSTRUCTION="Teach the main lesson in English using a concrete, age-appropriate visual and one short check for understanding."
CC_TEACHER_BRAIN_RESUME_INSTRUCTION="Resume the main lesson in English from the stored bridge without repeating the interruption answer."
CC_WHISPER_LANGUAGE=auto
CC_SPANISH_VOICE=Mónica
CC_CONTROL_PORT=4317
CC_LESSON_TITLE=Open Classroom Questions
